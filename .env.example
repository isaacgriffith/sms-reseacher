# Copy to .env and fill in values for local development
# NEVER commit .env to version control

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Production: postgresql+asyncpg://sms:smsdev@localhost:5432/smsresearcher
POSTGRES_PASSWORD=smsdev

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: anthropic | ollama
LLM_PROVIDER=anthropic
# Anthropic: claude-sonnet-4-6  |  Ollama: llama3.2:3b
LLM_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── researcher-mcp ────────────────────────────────────────────────────────────
RESEARCHER_MCP_URL=http://localhost:8002/sse
# Semantic Scholar unauthenticated rate limit: 100 req/min
SEMANTIC_SCHOLAR_RPM=100
# OpenAlex is generous; 300 req/min is well within limits
OPEN_ALEX_RPM=300
# Unpaywall requires an email for API access
UNPAYWALL_EMAIL=your-email@example.com
# SciHub: DISABLED by default — enabling may be illegal in your jurisdiction
# See researcher-mcp/README.md for legal notice before enabling
SCIHUB_ENABLED=false
SCIHUB_URL=https://sci-hub.se

# ── Academic Database API Keys (feature 006-database-search-and-retrieval) ────
# IEEE Xplore REST API — register at developer.ieee.org
IEEE_XPLORE_API_KEY=
# Elsevier (Scopus, ScienceDirect, Inspec) — register at dev.elsevier.com
ELSEVIER_API_KEY=
ELSEVIER_INST_TOKEN=
# Clarivate Web of Science Starter API
WOS_API_KEY=
# Springer Nature Metadata API — register at dev.springernature.com
SPRINGER_API_KEY=
# Semantic Scholar — optional; increases rate limit from shared pool to per-key
SEMANTIC_SCHOLAR_API_KEY=
# Google Scholar proxy URL — optional; strongly recommended for production use
# to avoid CAPTCHA blocks (e.g. http://user:pass@proxy.example.com:8080)
SCHOLARLY_PROXY_URL=
# MarkItDown OCR — LLM model used when enable_ocr=true (e.g. claude-haiku-4-5-20251001)
MARKITDOWN_OCR_MODEL=

# ── TOTP 2FA (feature 004-frontend-improvements) ──────────────────────────────
# Number of consecutive failed TOTP attempts before the account is temporarily locked
# TOTP_LOCKOUT_ATTEMPTS=5
# Duration (minutes) of a TOTP lockout
# TOTP_LOCKOUT_MINUTES=15
# Name shown in authenticator apps (e.g. Google Authenticator) as the issuer
# TOTP_ISSUER_NAME=SMS Researcher
